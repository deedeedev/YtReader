# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored and MUST NOT be committed.
#
# For local development, point storeFile to your keystore location.
# For CI, these values come from GitHub Secrets (environment variables).

storeFile=/path/to/your/release.jks
storePassword=your-keystore-password
keyAlias=release
keyPassword=your-key-password
